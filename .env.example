# === LLM 配置（主模型）===
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus

# === LLM 配置（轻量模型，用于 Model Router 简单任务）===
LLM_LITE_API_KEY=
LLM_LITE_BASE_URL=
LLM_LITE_MODEL=qwen-turbo

# === LLM 配置（强力模型，用于 Model Router 复杂任务）===
LLM_STRONG_API_KEY=
LLM_STRONG_BASE_URL=
LLM_STRONG_MODEL=

# === 应用配置 ===
APP_NAME=MyAgent
APP_HOST=0.0.0.0
APP_PORT=8001
APP_DEBUG=true
LOG_LEVEL=INFO

# === Token 限制 ===
MAX_TOKENS_PER_REQUEST=4096
MAX_RETRIES=3
REQUEST_TIMEOUT=60
