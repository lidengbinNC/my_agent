# === LLM 配置（主模型）===
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus

# === LLM 配置（轻量模型，用于 Model Router 简单任务）===
LLM_LITE_API_KEY=
LLM_LITE_BASE_URL=
LLM_LITE_MODEL=qwen-turbo

# === LLM 配置（强力模型，用于 Model Router 复杂任务）===
LLM_STRONG_API_KEY=
LLM_STRONG_BASE_URL=
LLM_STRONG_MODEL=

# === 应用配置 ===
APP_NAME=MyAgent
APP_HOST=0.0.0.0
APP_PORT=8001
APP_DEBUG=true
LOG_LEVEL=INFO

# === Token 限制 ===
MAX_TOKENS_PER_REQUEST=4096
MAX_RETRIES=3
REQUEST_TIMEOUT=60

# === 数据库（默认 SQLite，生产可换 PostgreSQL）===
# DATABASE_URL=sqlite+aiosqlite:///./my_agent.db
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost/my_agent

# === 记忆系统 ===
MEMORY_TYPE=window          # buffer / window / summary
MEMORY_WINDOW_SIZE=10       # WindowMemory 保留轮数
MEMORY_MAX_TOKENS=2000      # SummaryMemory 触发压缩阈值
MEMORY_RECENT_KEEP=6        # SummaryMemory 压缩时保留近期条数

# === 上下文窗口分层预算 ===
# 将整个上下文窗口按用途切分，各层在填充阶段就按预算截断
#
#  ┌─────────────────────────────────────────────────────┐
#  │              MAX_CONTEXT_TOKENS (8192)               │
#  ├──────────────┬────────────────┬─────────────────────┤
#  │ system(1500) │ few_shot(500)  │   output(1024)      │
#  ├──────────────┴────────────────┴─────────────────────┤
#  │   iteration_budget(800) × N 次 ReAct 迭代            │
#  ├─────────────────────────────────────────────────────┤
#  │   history_budget = 剩余（自动计算）                   │
#  └─────────────────────────────────────────────────────┘
MAX_CONTEXT_TOKENS=8192       # 模型最大上下文窗口（qwen-plus: 8K, gpt-4-turbo: 128K）
CTX_SYSTEM_BUDGET=1500        # System Prompt + 工具描述预留
CTX_FEW_SHOT_BUDGET=500       # Few-shot 示例预留
CTX_OUTPUT_BUDGET=1024        # 模型输出预留（不可被输入占用）
CTX_ITERATION_BUDGET=800      # 单次 ReAct 迭代（Thought+Action+Obs）预估
